{
  "functions": {
    "api/transcribe.js": { "maxDuration": 60, "memory": 1024 },
    "api/status.js": { "maxDuration": 30, "memory": 512 }
  },
  "rewrites": [
    { "source": "/api/transcribe", "destination": "/api/transcribe.js" },
    { "source": "/api/status", "destination": "/api/status.js" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
